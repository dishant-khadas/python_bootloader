# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Server Configuration
SERVER_URL=http://192.168.1.171:3000/
DEVICE_ID=41999990

# Serial Port Configuration
SERIAL_PORT=/dev/ttyAMA0
SERIAL_BAUD=115200
SERIAL_TIMEOUT=15

# GPIO Configuration (Raspberry Pi)
GPIOCHIP=gpiochip0
BL_DETECT_PIN=17
DISPLAY_ON_PIN=4

# Handshake Timeout (seconds)
HANDSHAKE_TIMEOUT=10

# Encryption Keys (REQUIRED for firmware updates)
# AES-256-CBC keys in hexadecimal format
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"  # for KEY
#                python3 -c "import secrets; print(secrets.token_hex(16))"  # for IV
AES_KEY_HEX=YOUR_32_BYTE_KEY_HERE_AS_64_HEX_CHARACTERS
AES_IV_HEX=YOUR_16_BYTE_IV_HERE_AS_32_HEX_CHARACTERS

# Example (DO NOT USE THESE VALUES IN PRODUCTION):
# AES_KEY_HEX=603deb1015ca71be2b73aef0857d77811f352c073b6108d72d9810a30914dff4
# AES_IV_HEX=2ef451f1de8a2fde02a9fc34728d2a66

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: For development (shows all details including hex dumps)
# INFO: For production (normal operations only)
# WARNING: Only warnings and errors
LOG_LEVEL=INFO
